<% content_for :title, "#{@tenant.dealership_name} — accountability dashboard" %>

<%= render "shared/frame", max_width: :board, wordmark: true do %>
  <%= render "shared/page_header",
        crumb: @tenant.dealership_name,
        title: "Accountability dashboard",
        subtitle: "Hi #{@tenant.gm_name.split.first}. Read-only summary; we'll grow this view in upcoming releases." %>

  <% if @digest.empty? %>
    <section class="rogue-card">
      <div class="rogue-empty">
        <h3 class="rogue-empty__title">No responsibilities yet.</h3>
        <p class="rogue-empty__body">Once your team starts answering onboarding questions, they'll appear here.</p>
      </div>
    </section>
  <% else %>
    <section class="rogue-card --padless">
      <table class="rogue-table">
        <thead>
          <tr>
            <th>Responsibility</th>
            <th>Owner</th>
            <th>Status</th>
            <th class="--right">Next due</th>
          </tr>
        </thead>
        <tbody>
          <% @digest.rows.each do |row| %>
            <%
              responsibility_label = row.responsibility.tenant_question.deliverable.capitalize
              next_due_label = row.next_due_at ? row.next_due_at.in_time_zone(@tenant.time_zone).strftime("%b %-d, %Y") : "—"
            %>
            <tr>
              <td class="--mobile-line1">
                <span class="rogue-table__primary"><%= responsibility_label %></span>
                <span class="rogue-table__mobile-only"><%= status_badge(row.status, web: true) %></span>
              </td>
              <td class="--mobile-hide"><%= row.primary_email %></td>
              <td class="--mobile-hide"><%= status_badge(row.status, web: true) %></td>
              <td class="--right --mobile-hide tabular"><%= next_due_label %></td>
              <td class="--mobile-only-cell --mobile-line2"><%= row.primary_email %> &middot; Next due: <%= next_due_label %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>

  <p class="rogue-footnote">This page is a snapshot. We'll send your next digest in seven days.</p>
<% end %>
